{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.bin/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Configurações de Caminho */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Desativar rigorosidade para o build passar */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
